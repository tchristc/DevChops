@page "/logs"
@using DevChops.Application.DTOs
@attribute [Authorize]
@inject ResourceGroupService ResourceGroupService
@inject LogQueryService LogQueryService
@inject ISavedFilterService SavedFilterService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject IDialogService DialogService

<PageTitle>Log Viewer – DevChops</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Correlated Log Viewer</MudText>

<!-- Filter bar -->
<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" md="5">
            <MudSelect T="string" @bind-Value="_selectedComponentId"
                       Label="Application Insights Resource" Variant="Variant.Outlined" Dense="true"
                       Disabled="@_loadingResources">
                <MudSelectItem T="string" Value="@string.Empty">— Select a resource —</MudSelectItem>
                @foreach (var c in _components)
                {
                    <MudSelectItem T="string" Value="@c.Id">@c.Name (@c.ResourceGroupName)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="_freeText" Label="Search text" Variant="Variant.Outlined"
                          Dense="true" Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          OnKeyUp="@OnSearchKeyUp" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string" @bind-Value="_selectedPreset" Label="Time Range"
                       Variant="Variant.Outlined" Dense="true">
                @foreach (var p in TimeRange.Presets)
                {
                    <MudSelectItem T="string" Value="@p.Label">@p.Display</MudSelectItem>
                }
                <MudSelectItem T="string" Value="@("custom")">Custom range…</MudSelectItem>
            </MudSelect>
        </MudItem>

        @if (_selectedPreset == "custom")
        {
            <MudItem xs="12">
                <MudDateRangePicker @bind-DateRange="_customDateRange"
                                    Label="Custom date range" Variant="Variant.Outlined" Dense="true" />
            </MudItem>
        }

        <MudItem xs="12">
            <MudText Typo="Typo.caption" Class="mb-1">Severity filter</MudText>
            <MudChipSet T="string" @bind-SelectedValues="_selectedSeverities"
                        MultiSelection="true" CheckMark="true">
                @foreach (var s in _severityOptions)
                {
                    <MudChip T="string" Value="@s" Text="@s" Size="MudBlazor.Size.Small" />
                }
            </MudChipSet>
        </MudItem>

        <MudItem xs="12">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary"
                           StartIcon="@Icons.Material.Filled.Search"
                           OnClick="@RunQuery"
                           Disabled="@(_querying || string.IsNullOrEmpty(_selectedComponentId))">
                    @(_querying ? "Searching…" : "Search")
                </MudButton>
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Clear"
                           OnClick="@ClearFilters">
                    Clear
                </MudButton>
                @if (_savedFilters.Count > 0)
                {
                    <MudMenu Label="Saved Filters" StartIcon="@Icons.Material.Filled.Bookmarks"
                             Variant="Variant.Outlined">
                        @foreach (var f in _savedFilters)
                        {
                            <MudMenuItem OnClick="@(() => ApplySavedFilter(f))">@f.Name</MudMenuItem>
                        }
                    </MudMenu>
                }
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.BookmarkAdd"
                           OnClick="@SaveCurrentFilter"
                           Disabled="@string.IsNullOrEmpty(_selectedComponentId)">
                    Save Filter
                </MudButton>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudPaper>

<!-- Results -->
@if (_querying)
{
    <MudProgressLinear Indeterminate="true" Color="MudBlazor.Color.Primary" Class="mb-3" />
    @for (int i = 0; i < 6; i++)
    {
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="44px" Class="mb-1" />
    }
}
else if (_queryError is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_queryError</MudAlert>
}
else if (_operations is not null)
{
    <MudText Typo="Typo.body2" Color="MudBlazor.Color.Secondary" Class="mb-2">
        @_operations.Count operation(s) found
    </MudText>

    <MudTable T="CorrelatedOperationDto" Items="@_operations" Hover="true" Dense="true"
              OnRowClick="@OnRowClick" RowClass="cursor-pointer" Elevation="1">
        <HeaderContent>
            <MudTh>Timestamp</MudTh>
            <MudTh>Operation Name</MudTh>
            <MudTh>Duration</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Events</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Timestamp">
                @context.StartTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
            </MudTd>
            <MudTd DataLabel="Operation Name">
                <MudText Style="max-width:420px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                    @context.OperationName
                </MudText>
            </MudTd>
            <MudTd DataLabel="Duration">@FormatDuration(context.Duration)</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="MudBlazor.Size.Small"
                         Color="@(context.HasErrors ? MudBlazor.Color.Error : MudBlazor.Color.Success)"
                         Text="@(context.ResultCode?.ToString() ?? (context.HasErrors ? "Error" : "OK"))" />
            </MudTd>
            <MudTd DataLabel="Events">
                <MudBadge Content="@context.EventCount.ToString()" Color="MudBlazor.Color.Primary" Overlap="true">
                    <MudIcon Icon="@Icons.Material.Filled.Timeline" Size="MudBlazor.Size.Small" />
                </MudBadge>
            </MudTd>
        </RowTemplate>
    </MudTable>
}
else
{
    <MudPaper Elevation="0" Class="d-flex flex-column align-center justify-center pa-12"
              Style="border:2px dashed var(--mud-palette-divider);">
        <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Size="MudBlazor.Size.Large" Color="MudBlazor.Color.Secondary" />
        <MudText Typo="Typo.h6" Color="MudBlazor.Color.Secondary" Class="mt-3">
            Select an Application Insights resource and run a search
        </MudText>
    </MudPaper>
}

<!-- Operation detail drawer -->
<MudDrawer @bind-Open="_drawerOpen" Anchor="Anchor.Right" Width="580px"
           Variant="DrawerVariant.Temporary" Elevation="4" ClipMode="DrawerClipMode.Never">
    @if (_selectedOperation is not null)
    {
        <MudDrawerHeader Class="d-flex align-center gap-2">
            <MudText Typo="Typo.h6"
                     Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;">
                @_selectedOperation.OperationName
            </MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           OnClick="@(() => _drawerOpen = false)" />
        </MudDrawerHeader>
        <MudContainer Class="pa-4">
            <MudGrid Class="mb-4">
                <MudItem xs="6">
                    <MudText Typo="Typo.caption">Start Time</MudText>
                    <MudText>@_selectedOperation.StartTime.ToLocalTime().ToString("HH:mm:ss.fff")</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption">Duration</MudText>
                    <MudText>@FormatDuration(_selectedOperation.Duration)</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption">Status</MudText>
                    <MudChip T="string" Size="MudBlazor.Size.Small"
                             Color="@(_selectedOperation.HasErrors ? MudBlazor.Color.Error : MudBlazor.Color.Success)"
                             Text="@(_selectedOperation.ResultCode?.ToString() ?? (_selectedOperation.HasErrors ? "Error" : "OK"))" />
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption">Operation ID</MudText>
                    <MudText Style="font-family:monospace;font-size:0.72rem;word-break:break-all;">
                        @_selectedOperation.OperationId
                    </MudText>
                </MudItem>
            </MudGrid>

            <MudText Typo="Typo.subtitle2" Class="mb-2">
                Timeline — @_selectedOperation.EventCount event(s)
            </MudText>
            <MudTimeline TimelinePosition="TimelinePosition.Start">
                @foreach (var ev in _selectedOperation.Events)
                {
                    <MudTimelineItem Color="@GetEventColor(ev.Type)" Size="MudBlazor.Size.Small">
                        <ItemContent>
                            <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">
                                @ev.Timestamp.ToLocalTime().ToString("HH:mm:ss.fff") · @ev.Type
                            </MudText>
                            <MudText>@(ev.Message ?? ev.OperationName)</MudText>
                            @if (!string.IsNullOrEmpty(ev.Details))
                            {
                                <MudExpansionPanel Text="Details" Dense="true">
                                    <pre style="font-size:0.72rem;white-space:pre-wrap;word-break:break-all;">@ev.Details</pre>
                                </MudExpansionPanel>
                            }
                        </ItemContent>
                    </MudTimelineItem>
                }
            </MudTimeline>
        </MudContainer>
    }
</MudDrawer>

@code {
    private List<AppInsightsComponent> _components = [];
    private List<SavedFilter> _savedFilters = [];
    private List<CorrelatedOperationDto>? _operations;
    private CorrelatedOperationDto? _selectedOperation;

    private string _selectedComponentId = string.Empty;
    private string _selectedPreset = "1h";
    private string _freeText = string.Empty;
    private DateRange? _customDateRange;
    private IReadOnlyCollection<string> _selectedSeverities = [];

    private bool _loadingResources = true;
    private bool _querying;
    private bool _drawerOpen;
    private string? _queryError;

    private static readonly string[] _severityOptions =
        ["Verbose", "Information", "Warning", "Error", "Critical"];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _components = (await ResourceGroupService.GetAppInsightsComponentsAsync()).ToList();
            var userId = await GetUserIdAsync();
            _savedFilters = (await SavedFilterService.GetForUserAsync(userId)).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load resources: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingResources = false;
        }
    }

    private async Task RunQuery()
    {
        if (string.IsNullOrEmpty(_selectedComponentId)) return;

        _querying = true;
        _queryError = null;
        _operations = null;

        try
        {
            var timeRange = BuildTimeRange();
            var filter = new LogFilter(
                TimeRange: timeRange,
                SeverityLevels: _selectedSeverities.Count > 0 ? [.. _selectedSeverities] : null,
                FreeText: string.IsNullOrWhiteSpace(_freeText) ? null : _freeText);

            _operations = (await LogQueryService.GetCorrelatedOperationsAsync(
                _selectedComponentId, filter)).ToList();
        }
        catch (Exception ex)
        {
            _queryError = $"Query failed: {ex.Message}";
        }
        finally
        {
            _querying = false;
        }
    }

    private TimeRange BuildTimeRange()
    {
        if (_selectedPreset == "custom"
            && _customDateRange?.Start is DateTime start
            && _customDateRange?.End is DateTime end)
        {
            return new TimeRange(
                new DateTimeOffset(start, TimeSpan.Zero),
                new DateTimeOffset(end, TimeSpan.Zero).AddDays(1),
                "custom");
        }
        return TimeRange.FromPresetKey(_selectedPreset);
    }

    private void OnRowClick(TableRowClickEventArgs<CorrelatedOperationDto> args)
    {
        _selectedOperation = args.Item;
        _drawerOpen = true;
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await RunQuery();
    }

    private void ClearFilters()
    {
        _freeText = string.Empty;
        _selectedSeverities = [];
        _selectedPreset = "1h";
        _customDateRange = null;
        _operations = null;
        _queryError = null;
    }

    private void ApplySavedFilter(SavedFilter f)
    {
        _selectedComponentId = f.AppInsightsResourceId ?? string.Empty;
        _freeText = f.FreeText ?? string.Empty;
        _selectedPreset = f.TimeRangePreset ?? "1h";
        _selectedSeverities = f.SeverityFilter.ToHashSet();
    }

    private async Task SaveCurrentFilter()
    {
        var userId = await GetUserIdAsync();
        var filter = new SavedFilter
        {
            UserId = userId,
            Name = $"Filter {DateTime.Now:HH:mm:ss}",
            AppInsightsResourceId = _selectedComponentId,
            SeverityFilter = [.. _selectedSeverities],
            TimeRangePreset = _selectedPreset,
            FreeText = _freeText,
        };
        await SavedFilterService.SaveAsync(filter);
        _savedFilters = (await SavedFilterService.GetForUserAsync(userId)).ToList();
        Snackbar.Add("Filter saved", Severity.Success);
    }

    private async Task<string> GetUserIdAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        return auth.User.FindFirst(
                   "http://schemas.microsoft.com/identity/claims/objectidentifier")?.Value
               ?? auth.User.Identity?.Name
               ?? "anonymous";
    }

    private static string FormatDuration(TimeSpan? d)
    {
        if (d is null) return "—";
        if (d.Value.TotalMilliseconds < 1000) return $"{d.Value.TotalMilliseconds:F0} ms";
        if (d.Value.TotalSeconds < 60)        return $"{d.Value.TotalSeconds:F1} s";
        return $"{d.Value.TotalMinutes:F1} min";
    }

    private static MudBlazor.Color GetEventColor(string type) => type switch
    {
        "request"    => MudBlazor.Color.Primary,
        "exception"  => MudBlazor.Color.Error,
        "trace"      => MudBlazor.Color.Info,
        "dependency" => MudBlazor.Color.Secondary,
        _            => MudBlazor.Color.Default,
    };
}
