@page "/Error"
@using System.Diagnostics
@layout MainLayout

<PageTitle>Error – DevChops</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex flex-column align-center justify-center mt-16">
    <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Style="font-size:6rem;" Color="MudBlazor.Color.Error" />
    <MudText Typo="Typo.h4" Class="mt-4">Something went wrong</MudText>
    <MudText Typo="Typo.body1" Color="MudBlazor.Color.Secondary" Class="mt-2" Align="MudBlazor.Align.Center">
        An unexpected error occurred while processing your request.
    </MudText>

    @if (ShowRequestId)
    {
        <MudText Typo="Typo.caption" Class="mt-3">
            Request ID: <code>@RequestId</code>
        </MudText>
    }

    <MudStack Row="true" Spacing="2" Class="mt-6">
        <MudButton Href="/" Variant="Variant.Filled" Color="MudBlazor.Color.Primary"
                   StartIcon="@Icons.Material.Filled.Home">
            Back to Dashboard
        </MudButton>
        <MudButton OnClick="@(() => Navigation.Refresh(forceReload: true))"
                   Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh">
            Reload
        </MudButton>
    </MudStack>
</MudContainer>

@inject NavigationManager Navigation

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
